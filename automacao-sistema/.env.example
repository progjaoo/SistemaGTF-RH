# Timezone dos containers e dos crons do n8n.
TZ=America/Sao_Paulo

# Portas expostas no host.
N8N_PORT=5678
WAHA_PORT=3000

# Imagens Docker.
N8N_IMAGE_TAG=latest
WAHA_IMAGE_TAG=latest

# URL publica do n8n se voce publicar via dominio.
# Localmente pode manter http://localhost:5678/
N8N_WEBHOOK_URL=http://localhost:5678/

# Gere uma chave longa e fixa. Nao altere depois, senao credenciais criptografadas podem quebrar.
N8N_ENCRYPTION_KEY=troque_por_uma_chave_longa_aleatoria

# Login do painel n8n.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque_por_uma_senha_forte

# WAHA.
WAHA_ENGINE=NOWEB
WAHA_API_KEY=troque_por_uma_api_key_longa
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=troque_por_uma_senha_forte
WAHA_WORKER_ID=sistema-rh-waha
WAHA_SESSION_NAME=default
WAHA_PRINT_QR=False
WAHA_RESTART_ALL_SESSIONS=True
WAHA_PUBLIC_URL=http://localhost:3000

# Webhook WAHA -> n8n.
# Em Docker, mantenha o endereco interno abaixo.
WAHA_WEBHOOK_URL=http://n8n:5678/webhook/waha-poll-vote
WAHA_WEBHOOK_EVENTS=poll.vote,poll.vote.failed
WAHA_HOOK_RETRIES_POLICY=linear
WAHA_HOOK_RETRIES_DELAY_SECONDS=2
WAHA_HOOK_RETRIES_ATTEMPTS=4

# URL interna do WAHA vista pelo n8n.
N8N_WAHA_URL=http://waha:3000

# IDs do WhatsApp.
# Grupo: formato comum 1234567890@g.us
# Gestora em DM: formato comum 5511999999999@c.us
WA_GROUP_ID=preencher_depois@g.us
WA_MANAGER_CHAT_ID=preencher_depois@c.us

# Texto das opcoes da enquete. O workflow usa esses textos para filtrar confirmacoes.
POLL_YES_OPTION=Eu peguei
POLL_NO_OPTION=Nao peguei

# Mapa opcional para resolver nomes quando o payload de poll.vote vier apenas com telefone.
# Use JSON em uma linha. Chaves podem ser chatId completo ou numero sem sufixo.
CONTACT_NAME_MAP={"5511999999999@c.us":"Nome Exemplo","5511888888888":"Outro Nome"}

# Lista opcional de participantes esperados para apontar quem nao respondeu ate 18h.
# Pode ser lista de chatIds ou objetos com id/name.
EXPECTED_PARTICIPANTS=[{"id":"5511999999999@c.us","name":"Nome Exemplo"}]
